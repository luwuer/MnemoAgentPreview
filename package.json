{
  "name": "mnemo",
  "version": "0.1.0",
  "private": true,
  "description": "Mnemo — 具有人类记忆机制的个人助理 Agent（记忆图 + 渐进式展开 + Skills/MCP/Rules）",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @mnemo/server dev",
    "dev:web": "pnpm --filter @mnemo/web dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rimraf dist node_modules/.cache"
  },
  "devDependencies": {
    "rimraf": "^5.0.10",
    "typescript": "^5.6.3"
  }
}
