# Mnemo 环境变量示例
# 复制为 .env 并填入实际值
# cp .env.example .env

# DeepSeek API Key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 通义千问 API Key (https://dashscope.console.aliyun.com/)
# DASHSCOPE_API_KEY=sk-your-qwen-key

# 智谱 GLM API Key (https://open.bigmodel.cn/)
# ZHIPU_API_KEY=your-glm-key

# 服务端口（可选，默认 3000）
# PORT=3000

# 配置文件路径（可选，默认 config/mnemo.config.local.yaml）
# MNEMO_CONFIG=config/mnemo.config.local.yaml
